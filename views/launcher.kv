#:kivy 2.0
#:import StarfieldBackground launcher.widgets.background.StarfieldBackground
#:import AppTile launcher.widgets.tile.AppTile
#:import StatsTapArea launcher.widgets.stats_overlay.StatsTapArea

<AppTile>:
    # Styling done in Python

<StarfieldBackground>:
    # Styling done in Python

# Main layout
FloatLayout:
    id: root_layout

    # Animated starfield background
    StarfieldBackground:
        id: starfield
        pos: 0, 0
        size: root.size

    # Hidden 8x-tap area top center for statistics screen
    StatsTapArea:
        id: stats_tap_area
        size_hint: 0.15, 0.08
        pos_hint: {'center_x': 0.5, 'top': 1}

    # Container for app grid – centered
    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'center'
        # Proportional padding, top/bottom balanced (title removed)
        padding: root.width * 0.05, root.height * 0.08, root.width * 0.05, root.height * 0.08

        # App grid with dynamic spacing
        GridLayout:
            id: app_grid
            cols: 3
            # Spacing proportional to window size (~4% of width)
            spacing: root.width * 0.04, root.height * 0.05
            size_hint: 0.85, 0.7

    # Dev mode indicator (bottom left)
    Label:
        id: dev_label
        text: "DEV MODE - ESC beenden | F11 Vollbild"
        font_size: '14sp'
        size_hint: None, None
        size: self.texture_size[0] + dp(20), self.texture_size[1] + dp(10)
        pos: dp(10), dp(10)
        color: 1, 1, 0, 0.8
        opacity: 1 if app.is_dev_mode else 0
