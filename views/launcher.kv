#:kivy 2.0
#:import StarfieldBackground launcher.widgets.background.StarfieldBackground
#:import AppTile launcher.widgets.tile.AppTile

<AppTile>:
    # Styling wird in Python gemacht

<StarfieldBackground>:
    # Styling wird in Python gemacht

# Haupt-Layout
FloatLayout:
    id: root_layout

    # Animierter Sternenhimmel-Hintergrund
    StarfieldBackground:
        id: starfield
        pos: 0, 0
        size: root.size

    # Titel oben
    Label:
        id: title_label
        text: "* Astro Explorer *"
        font_size: min(root.width * 0.035, 48)  # Skaliert mit Fenster
        bold: True
        size_hint: None, None
        size: self.texture_size[0] + dp(40), self.texture_size[1] + dp(20)
        pos_hint: {'center_x': 0.5}
        top: root.top - root.height * 0.03
        color: 1, 1, 1, 0.95

    # Container für das App-Grid - ZENTRIERT
    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'center'
        # Padding auch proportional
        padding: root.width * 0.05, root.height * 0.12, root.width * 0.05, root.height * 0.06

        # App-Grid mit dynamischem Spacing
        GridLayout:
            id: app_grid
            cols: 3
            # Spacing proportional zur Fenstergröße (ca. 4% der Breite)
            spacing: root.width * 0.04, root.height * 0.05
            size_hint: 0.85, 0.7

    # Dev-Mode Indikator (unten links)
    Label:
        id: dev_label
        text: "DEV MODE - ESC beenden | F11 Vollbild"
        font_size: '14sp'
        size_hint: None, None
        size: self.texture_size[0] + dp(20), self.texture_size[1] + dp(10)
        pos: dp(10), dp(10)
        color: 1, 1, 0, 0.8
        opacity: 1 if app.is_dev_mode else 0
